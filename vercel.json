{
  "buildCommand": "npm install --legacy-peer-deps && npm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --legacy-peer-deps",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/sitemap.xsl",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://amerilendloan-production.up.railway.app/api/:path*" },
    { "source": "/health/:path*", "destination": "https://amerilendloan-production.up.railway.app/health/:path*" },
    { "source": "/health", "destination": "https://amerilendloan-production.up.railway.app/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

